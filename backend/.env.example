# Aiven MySQL SSL Certificates ("Require and Verify CA")
MYSQL_SSL_REQUIRED=false
MYSQL_SSL_CA_PATH=./certs/ca.pem
MYSQL_SSL_CERT_PATH=./certs/service.cert
MYSQL_SSL_KEY_PATH=./certs/service.key
# Alternatively, inline certificate content for cloud hosts (e.g. Render):
# MYSQL_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# MYSQL_SSL_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# MYSQL_SSL_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

